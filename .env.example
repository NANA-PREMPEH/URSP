# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# Configure this in your local environment or hosting platform secrets panel.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL: Optional. Defaults to the OpenRouter free router.
OPENROUTER_MODEL="openrouter/free"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
