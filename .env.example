# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# Configure this in your local environment or hosting platform secrets panel.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL: Optional. Defaults to the OpenRouter free router.
OPENROUTER_MODEL="openrouter/free"

# APP_URL: Optional canonical URL for this app.
# On Vercel you can set this to your production domain, for example:
# APP_URL="https://your-project.vercel.app"
# Used for OpenRouter referer metadata and any future self-referential links.
APP_URL="MY_APP_URL"
